{
  "name": "Safe Telegram Auto Request Bot",
  "description": "Securely auto-approves join requests for Telegram groups and channels using official Bot API.",
  "keywords": ["telegram", "bot", "auto-approve", "join-request", "safe", "python"],
  "env": {
    "BOT_TOKEN": { 
      "description": "Bot token from @BotFather (e.g., 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11)", 
      "required": true 
    }
  },
  "formation": { 
    "worker": { 
      "quantity": 1, 
      "size": "eco" 
    } 
  },
  "buildpacks": [
    { "url": "heroku/python" }
  ]
}
